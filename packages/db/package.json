{
  "name": "@legabit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "generate": "dotenv -e ../../apps/web/.env.local -- prisma generate",
    "migrate": "dotenv -e ../../apps/web/.env.local -- prisma migrate dev",
    "studio": "dotenv -e ../../apps/web/.env.local -- prisma studio",
    "build": "dotenv -e ../../apps/web/.env.local -- prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
