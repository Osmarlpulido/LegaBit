# PostgreSQL (solo Prisma CLI: migrate / studio / generate). NO es necesario para
# el newsletter, que funciona con la API REST de Supabase y la clave de servidor.
# Cópialas desde Supabase Dashboard → Connect.
# DATABASE_URL = pooler "Transaction" (6543); DIRECT_URL = directa (5432).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase (frontend / SSR + login con Google)
# Login con Google: actívalo en Dashboard → Authentication → Providers → Google
# y añade en URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback  y  https://TU-DOMINIO/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Solo servidor (no exponer al cliente). SUPABASE_SECRET_KEY (`sb_secret_…`) es la
# credencial recomendada; SUPABASE_SERVICE_ROLE_KEY es opcional/legacy.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# UploadThing
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# OpenAI (solo servidor)
OPENAI_API_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Web3 / Wallet Connect
# Obtén tu projectId en: https://cloud.walletconnect.com (plan gratuito disponible)
# Sin este ID el botón de wallet abre en modo demo (solo MetaMask injected funcionará)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# CoinGecko API
# El plan gratuito (Demo API) no requiere key pero tiene límites de rate.
# Regístrate en https://www.coingecko.com/en/api para obtener una key gratuita.
# Sin key, las llamadas funcionan pero pueden ser limitadas por IP.
COINGECKO_API_KEY=

# Marketing (landing) — opcional; si vacío se usan los enlaces públicos por defecto
NEXT_PUBLIC_LEGABIT_DISCORD_URL=https://discord.gg/jtz9dve2
NEXT_PUBLIC_LEGABIT_TELEGRAM_URL=https://t.me/Legabit_org
NEXT_PUBLIC_LEGABIT_YOUTUBE_URL=https://www.youtube.com/@legabitERC-20
# Compatibilidad: si no defines DISCORD_URL, puede usarse solo este para Discord
NEXT_PUBLIC_LEGABIT_COMMUNITY_URL=
